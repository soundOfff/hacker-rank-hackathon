# Copy to .env and fill in. Never commit the real key.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — OpenRouter attribution headers (used for app rankings only).
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=hackerrank-orchestrate

# Optional — override the default OpenRouter slugs (defaults shown).
# ORCH_STAGE1_MODEL=anthropic/claude-haiku-4.5
# ORCH_STAGE2_MODEL=anthropic/claude-sonnet-4.6
# ORCH_STAGE2_ESCALATION_MODEL=anthropic/claude-opus-4.8

# Optional — arm the single-route escalation triggers (ADR-0003). All ship OFF
# (cost-first: Sonnet on every claim). Set to 1 to route hard rows to Opus.
# ORCH_ROUTE_ON_INSTRUCTION_TEXT=1
# ORCH_ROUTE_ON_MULTI_PART=1
# ORCH_ROUTE_ON_HISTORY_RISK=1

# Optional — shared response cache (Item 3). Unset => local filesystem cache.
# Compose sets this automatically to the bundled Redis service.
# REDIS_URL=redis://localhost:6379/0

# Optional — pgvector image store for reused-image / fraud-ring detection
# (Item 4). Unset => vector store skipped entirely. Compose sets this to the
# bundled Postgres+pgvector service.
# DATABASE_URL=postgresql://orchestrate:orchestrate@localhost:5432/orchestrate
# ORCH_EMBED_BACKEND=phash      # phash (default, light) | clip (needs sentence-transformers)
